# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=docs_db

# LLM provider (OpenAI-compatible chat completions API)
LLM_PROVIDER=meta
LLM_BASE_URL=https://inference.do-ai.run/v1
LLM_API_KEY=
LLM_MODEL=llama-4-maverick
LLM_REQUEST_TIMEOUT=120

# Retrieval / prompt shaping (optional overrides)
MAX_DOCS_PER_QUERY=3
MAX_CHARS_PER_DOC=6000
MAX_TOTAL_CONTEXT_CHARS=12000

# CORS (comma-separated origins, or * for all)
CORS_ALLOW_ORIGINS=*

# Only requests with this exact user_role are processed; everything else
# gets rejected with 403 before touching the DB or LLM.
REQUIRED_USER_ROLE=agent

LOG_LEVEL=INFO

# Rate limiting (in-memory, per IP, requires a single api worker/replica)
RATE_LIMIT_PER_MINUTE=30

# Reject request bodies larger than this many bytes before hitting DB/LLM
MAX_REQUEST_BODY_BYTES=20000
