{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run API",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": ["src.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "env": {"PYTHONPATH": "${workspaceFolder}"}
    },
    {
      "name": "Run Ingestion",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/ingest.py",
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "env": {"PYTHONPATH": "${workspaceFolder}"}
    },
    {
      "name": "Run Evaluation",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/evaluate.py",
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "env": {"PYTHONPATH": "${workspaceFolder}"}
    },
    {
      "name": "Run Tests",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": ["tests", "-v"],
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "env": {"PYTHONPATH": "${workspaceFolder}"}
    }
  ]
}
