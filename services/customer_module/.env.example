PGHOST=localhost
PGPORT=5432
PGDATABASE=kiotel
PGUSER=queryweaver_readonly
PGPASSWORD=change_me

PG_STATEMENT_TIMEOUT_MS=5000
DEFAULT_ROW_LIMIT=5

# Result-formatting: long text fields (over this many words) get
# auto-summarized in responses unless the question contains "raw".
SUMMARY_WORD_THRESHOLD=15
SUMMARY_MAX_TOKENS=200

# Hosted LLM (OpenAI-compatible API) used for SQL generation + summarization.
# Do NOT commit a real key here — this file is the template, not your .env.
LLM_PROVIDER=meta
LLM_BASE_URL=https://inference.do-ai.run/v1
LLM_API_KEY=
LLM_MODEL=llama-4-maverick

# Hybrid (lexical + semantic) retrieval store: pgvector + Postgres full-text
# search, on its own STANDALONE `vectordb` container/volume/role — fully
# separate from the `postgres` service and PGUSER/PGPASSWORD (your business
# DB credentials) in every way. Only stores table DDL/documentation/example
# SQL, never real row data.
VECTOR_DB_HOST=vectordb
VECTOR_DB_PORT=5432
VECTOR_DB_NAME=vanna_vectors
VECTOR_DB_USER=vanna
VECTOR_DB_PASSWORD=vanna_local_pw
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RETRIEVAL_TOP_K=6

# Optional: set to require an X-API-Key header on the HTTP API. Leave blank
# to run the API open (fine for local/dev only).
API_KEY=
